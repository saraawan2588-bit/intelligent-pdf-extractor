# OpenAI Configuration
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4

# Application Settings
MAX_PDF_PAGES=50
TIMEOUT=300
TEMPERATURE=0.3
MAX_TOKENS=2000

# File Upload Settings
MAX_UPLOAD_SIZE=50  # MB
ALLOWED_FORMATS=.pdf,.PDF

# Output Settings
OUTPUT_FORMAT=xlsx
INCLUDE_CONFIDENCE=true
